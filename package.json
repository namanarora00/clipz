{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "clipz",
  "title": "Clipz",
  "description": "I made a clipboard manager because apparently that was still a problem. It has AI too, because of course it does",
  "icon": "extension-icon.png",
  "author": "naman",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-history",
      "title": "Clipboard History",
      "subtitle": "Clipz",
      "description": "Search clipboard history. Press ⌘↵ to ask AI.",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "aiMode",
      "title": "AI Mode",
      "description": "Which AI backend to use",
      "type": "dropdown",
      "default": "ollama",
      "required": false,
      "data": [
        {
          "title": "Raycast AI (Pro)",
          "value": "raycast"
        },
        {
          "title": "Local Ollama",
          "value": "ollama"
        },
        {
          "title": "OpenAI",
          "value": "openai"
        },
        {
          "title": "Anthropic",
          "value": "anthropic"
        },
        {
          "title": "None (disable AI)",
          "value": "none"
        }
      ]
    },
    {
      "name": "ollamaUrl",
      "title": "Ollama URL",
      "description": "URL where Ollama is running (Ollama mode only)",
      "type": "textfield",
      "default": "http://localhost:11434",
      "required": false
    },
    {
      "name": "ollamaModel",
      "title": "Ollama Model",
      "description": "Model for Ollama mode",
      "type": "textfield",
      "default": "qwen2.5:3b",
      "required": false
    },
    {
      "name": "embeddingModel",
      "title": "Embedding Model",
      "description": "Ollama model used for semantic clipboard search",
      "type": "textfield",
      "default": "nomic-embed-text",
      "required": false
    },
    {
      "name": "apiKey",
      "title": "API Key",
      "description": "OpenAI or Anthropic API key",
      "type": "password",
      "required": false
    },
    {
      "name": "apiModel",
      "title": "Cloud Model",
      "description": "OpenAI: gpt-4o-mini · Anthropic: claude-haiku-4-5-20251001",
      "type": "textfield",
      "default": "gpt-4o-mini",
      "required": false
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.90.0",
    "@raycast/utils": "^1.19.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.13.14",
    "@types/react": "18.3.3",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo 'Use npm run publish' && exit 1",
    "publish": "npx @raycast/api@latest publish",
    "setup": "bash scripts/setup.sh"
  }
}
